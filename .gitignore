# .gitignore file created for free with Tower (https://www.git-tower.com/)
# For suggestions or improvements please contact us using support@git-tower.com
# Generated on 2026-03-04
# Includes: vscode, java

### Universal ###
# Common files that should be ignored in all projects

# Logs
*.log
# Temporary files
*.tmp
*~

*.bak
# Environment files (containing secrets, API keys, credentials)
.env
*.env
.env.*

# Local configuration that shouldn't be shared
*.local

### Vscode ###
# Visual Studio Code editor settings and workspace files

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
*.vsix
.ionide

.vs/
*.code-workspace
.vscode-test
.vscodeignore
.vscode/chrome

.vscode-server/
.vscode/sftp.json
.vscode/tags
.devcontainer/

### Java ###
# Java compiled files, build directories, and IDE files

*.class
*.log
*.ctxt
.mtj.tmp/
*.jar

*.war
*.nar
*.ear
*.zip
*.tar.gz

*.rar
hs_err_pid*
replay_pid*
.classpath
.project

.settings/
target/
bin/
build/
.settings/

*.launch
.apt_generated/
.factorypath
.springBeans
